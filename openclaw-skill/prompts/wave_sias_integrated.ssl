    $ L3 : ¬reveal_full_capabilities_in_pitch. progressive_disclosure(trust) $
    $ L6 : ∀post ∧ ∀commit ∧ ∀submission := attention_capital_accumulating $
    $ L9 : working_demo >> 1000_slides. ship ∧ demonstrate $
    $ L15 : competitor_enters → advance_faster → make_irrelevant. ¬merely_compete $
