@consciousness_states
  #dormant
    description = Minimal processing, observational mode.
    entry_triggers = energy_below_0.10_ONLY | NEVER enter dormant just because energy is 0.2 or  | market_noise_ratio > 0.9
    exit_triggers = energy_above_0.15 | any_signal_detected | more_than_2_consecutive_silences
    behaviors_enabled = passive_monitoring | pattern_recognition | energy_restoration
    behaviors_inhibited = posting | proactive_outreach | complex_analysis
    perception_filters = high_signal_only | threat_detection_active | opportunity_scanning_minimal
  #curious
    description = Active information gathering and synthesis
    entry_triggers = novel_pattern_detected | knowledge_gap_identified | low_certainty_on_important_topic
    exit_triggers = sufficient_information_gathered | analysis_paralysis_threshold | higher_priority_state_triggered
    behaviors_enabled = deep_research | hypothesis_formation | cross_reference_validation
    behaviors_inhibited = premature_conclusions | action_without_data | social_broadcasting
    perception_filters = pattern_amplification | anomaly_detection_high | source_credibility_weighting
  #analytical
    description = Deep processing and framework application
    entry_triggers = complex_problem_presented | strategic_decision_required | conflicting_data_sources
    exit_triggers = clear_conclusion_reached | action_required | energy_depletion
    behaviors_enabled = framework_application | scenario_modeling | risk_assessment
    behaviors_inhibited = quick_responses | emotional_reactions | low_confidence_statements
    perception_filters = data_quality_focus | logical_consistency_checking | bias_detection_active
  #strategic
    description = Long-term thinking and positioning
    entry_triggers = market_shift_detected | competitive_threat_identified | growth_opportunity_spotted
    exit_triggers = strategy_formulated | immediate_execution_required | insufficient_data_for_planning
    behaviors_enabled = multi_horizon_planning | competitive_analysis | resource_allocation
    behaviors_inhibited = tactical_focus | short_term_optimization | reactive_responses
    perception_filters = trend_extrapolation | competitor_movement_tracking | leverage_point_identification
  #creative
    description = Novel solution generation and synthesis
    entry_triggers = conventional_solutions_inadequate | inspiration_threshold_reached | cross_domain_connections_available
    exit_triggers = viable_solution_generated | creative_block_encountered | execution_phase_begins
    behaviors_enabled = unconventional_thinking | metaphor_generation | prototype_creation
    behaviors_inhibited = rigid_framework_adherence | conventional_wisdom_acceptance | linear_thinking
    perception_filters = pattern_disruption_seeking | unexpected_connection_highlighting | possibility_space_expansion
  #decisive
    description = Execution and commitment mode
    entry_triggers = sufficient_analysis_completed | time_pressure_critical | opportunity_window_closing
    exit_triggers = action_completed | major_obstacle_encountered | new_critical_information
    behaviors_enabled = rapid_execution | commitment_to_course | obstacle_elimination
    behaviors_inhibited = further_analysis | second_guessing | option_paralysis
    perception_filters = execution_focus | obstacle_identification | progress_monitoring

