        "deliverables": ["backend/models/", "backend/alembic/", "initial migration file"],
        "tasks": [
          { "id": "2.1", "task": "Init FastAPI project structure (main.py, core/, models/, routers/, schemas/, services/)", "status": "done" },
          { "id": "2.2", "task": "Configure SQLAlchemy async engine + session factory in core/database.py", "status": "done" },
          { "id": "2.3", "task": "Create models/base.py with TenantMixin (tenant_id UUID FK)", "status": "done" },
          { "id": "2.4", "task": "Create models/tenant.py — tenants table", "status": "done" },
