    "dependency_graph": "Phase1 → Phase2 → Phase3 → [Phase4, Phase5] → Phase6 → Phase7 → Phase8 → Phase9 → Phase10 → Phase10.5 → Phase11 → Phase12 → Phase13 → [Phase14→17, Phase15→16]",
    "phases": [
