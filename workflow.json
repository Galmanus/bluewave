{
  "project": {
    "name": "Bluewave",
    "tagline": "AI Creative Operations Agent",
    "one_liner": "The AI agent that sees your media, writes your copy, enforces your brand, and ships your content — on autopilot.",
    "description": "AI-native creative operations agent for marketing agencies, AV teams, and production companies. Combines DAM + AI content generation (Claude Vision) + brand compliance + approval workflows + multi-channel distribution in a single autonomous agent that learns your brand over time.",
    "category": "AI Creative Operations Agent",
    "version": "0.2.0",
    "created": "2026-03-17",
    "positioning": {
      "from": "DAM tool that stores files ($12/user)",
      "to": "AI agent that runs creative operations ($29-149/user + $0.05/action)",
      "competitive_set": ["Bynder", "Air.inc", "Jasper", "Copy.ai", "Buffer", "Frontify"],
      "differentiator": "Agent learns your brand voice from approved content — switching cost grows every month (data moat)"
    }
  },

  "tech_stack": {
    "backend": {
      "language": "Python 3.11",
      "framework": "FastAPI 0.110.0",
      "orm": "SQLAlchemy 2.0.27 (async)",
      "migrations": "Alembic 1.13.1",
      "auth": "python-jose (HS256 JWT) + passlib (bcrypt)",
      "server": "Uvicorn 0.27.1"
    },
    "frontend": {
      "language": "TypeScript 5.5",
      "framework": "React 18.3",
      "bundler": "Vite 5.4",
      "styling": "Tailwind CSS 3.4",
      "state_management": "TanStack React Query 5.45",
      "routing": "React Router DOM 6.23",
      "http_client": "Axios 1.7 (exponential backoff retry)"
    },
    "database": {
      "engine": "PostgreSQL 16",
      "strategy": "Row-level multi-tenant isolation via tenant_id"
    },
    "infrastructure": {
      "orchestration": "Docker Compose",
      "network": "bluewave_network (bridge)",
      "services": ["postgres", "backend", "frontend"]
    }
  },

  "architecture": {
    "multi_tenancy": {
      "strategy": "row_level_isolation",
      "mechanism": "SQLAlchemy session event auto-injects WHERE tenant_id = :tid on every SELECT/UPDATE/DELETE",
      "enforcement": "TenantMixin base class adds non-nullable tenant_id UUID FK to all tenant-scoped models",
      "indexes": "Composite (tenant_id, id) on users and media_assets tables"
    },
    "authentication": {
      "method": "JWT (HS256)",
      "access_token": { "ttl_minutes": 30, "transport": "Authorization Bearer header" },
      "refresh_token": { "ttl_days": 7, "transport": "httpOnly Secure SameSite=Strict cookie" },
      "jwt_payload": {
        "sub": "user_id (UUID)",
        "tenant_id": "tenant_id (UUID)",
        "role": "admin | editor | viewer",
        "exp": "unix_timestamp",
        "type": "access | refresh"
      }
    },
    "authorization": {
      "roles": {
        "admin": "Full access: CRUD users, CRUD assets, approve/reject workflow",
        "editor": "Upload assets, edit captions/hashtags, submit for approval",
        "viewer": "Read-only access to assets and own profile"
      },
      "enforcement": "FastAPI Depends() — get_current_user() + require_role()"
    },
    "approval_workflow": {
      "states": ["draft", "pending_approval", "approved"],
      "transitions": {
        "submit": { "from": "draft", "to": "pending_approval", "allowed_roles": ["editor", "admin"] },
        "approve": { "from": "pending_approval", "to": "approved", "allowed_roles": ["admin"] },
        "reject": { "from": "pending_approval", "to": "draft", "allowed_roles": ["admin"], "requires_comment": true }
      }
    },
    "ai_integration": {
      "current": "ClaudeAIService (real Anthropic Claude API with vision) + StubAIService fallback",
      "provider": "Anthropic Claude API (claude-sonnet-4-20250514)",
      "features": ["Vision-based image analysis for captions/hashtags", "Filename inference for non-image media", "Graceful fallback to stubs when no API key"],
      "trigger": "Background task auto-runs after file upload",
      "outputs": ["caption (AI-generated from image content or filename)", "hashtags (AI-generated JSON array)"],
      "usage_tracking": "ai_usage_logs table records every AI action for metered billing",
      "pricing": { "per_action": "$0.05", "brand_voice": "$0.25", "content_brief": "$1.00" }
    },
    "file_storage": {
      "current": "Local Docker volume at /app/uploads/{tenant_id}/{uuid}_{filename}",
      "validation": { "allowed_mime": ["image/*", "video/*"], "max_size_mb": 50 },
      "swap_strategy": "Replace storage adapter for S3/MinIO — API contract unchanged"
    },
    "resilience": {
      "retry": {
        "max_attempts": 3,
        "strategy": "exponential_backoff",
        "base_delay_ms": 500,
        "delays": ["500ms", "1000ms", "2000ms"],
        "jitter": "±20%",
        "retryable_codes": [408, 429, 500, 502, 503, 504],
        "retryable_conditions": ["network_error", "timeout", "dns_failure"]
      }
    }
  },

  "database_schema": {
    "tables": {
      "tenants": {
        "columns": {
          "id": "UUID PRIMARY KEY DEFAULT uuid4",
          "name": "VARCHAR(255) NOT NULL",
          "created_at": "TIMESTAMP NOT NULL DEFAULT now()"
        },
        "relationships": ["has_many users", "has_many media_assets"]
      },
      "users": {
        "columns": {
          "id": "UUID PRIMARY KEY DEFAULT uuid4",
          "tenant_id": "UUID NOT NULL FK → tenants.id",
          "email": "VARCHAR(320) NOT NULL UNIQUE",
          "hashed_password": "VARCHAR(128) NOT NULL",
          "full_name": "VARCHAR(255) NOT NULL",
          "role": "ENUM(admin, editor, viewer) NOT NULL",
          "created_at": "TIMESTAMP NOT NULL DEFAULT now()"
        },
        "indexes": ["ix_users_tenant_id", "ix_users_tenant_id_id (composite)"],
        "relationships": ["belongs_to tenant", "has_many media_assets"]
      },
      "media_assets": {
        "columns": {
          "id": "UUID PRIMARY KEY DEFAULT uuid4",
          "tenant_id": "UUID NOT NULL FK → tenants.id",
          "uploaded_by": "UUID NOT NULL FK → users.id",
          "file_path": "VARCHAR(512) NOT NULL",
          "file_type": "VARCHAR(100) NOT NULL",
          "file_size": "BIGINT NOT NULL",
          "caption": "TEXT NULLABLE",
          "hashtags": "VARCHAR[] NULLABLE (PostgreSQL ARRAY)",
          "status": "ENUM(draft, pending_approval, approved) NOT NULL",
          "rejection_comment": "TEXT NULLABLE",
          "created_at": "TIMESTAMPTZ NOT NULL DEFAULT now()",
          "updated_at": "TIMESTAMPTZ NOT NULL DEFAULT now() ON UPDATE now()"
        },
        "indexes": ["ix_media_assets_tenant_id", "ix_media_assets_tenant_id_id (composite)"],
        "relationships": ["belongs_to tenant", "belongs_to user (uploaded_by)"]
      },
      "ai_usage_logs": {
        "columns": {
          "id": "UUID PRIMARY KEY DEFAULT uuid4",
          "tenant_id": "UUID NOT NULL FK → tenants.id",
          "user_id": "UUID NOT NULL FK → users.id",
          "asset_id": "UUID NULLABLE FK → media_assets.id ON DELETE SET NULL",
          "action_type": "ENUM(caption, hashtags, compliance_check, auto_tag, brand_voice, content_brief, resize) NOT NULL",
          "model_used": "VARCHAR(100) NOT NULL",
          "input_tokens": "INTEGER NOT NULL DEFAULT 0",
          "output_tokens": "INTEGER NOT NULL DEFAULT 0",
          "cost_millicents": "BIGINT NOT NULL DEFAULT 0 (1/1000 cent precision)",
          "created_at": "TIMESTAMPTZ NOT NULL DEFAULT now()"
        },
        "indexes": ["ix_ai_usage_tenant_created (tenant_id, created_at)", "ix_ai_usage_tenant_action (tenant_id, action_type)"],
        "purpose": "Metered billing, usage analytics, rate limiting"
      }
    }
  },

  "api_endpoints": {
    "prefix": "/api/v1",
    "groups": {
      "health": [
        { "method": "GET", "path": "/health", "auth": false, "description": "Service health check" }
      ],
      "auth": [
        { "method": "POST", "path": "/auth/register", "auth": false, "description": "Create tenant + admin user", "request": "{ tenant_name, email, password, full_name }", "response": "{ tenant_id, user_id, message }" },
        { "method": "POST", "path": "/auth/login", "auth": false, "description": "Authenticate and get tokens", "request": "{ email, password }", "response": "{ access_token, token_type } + Set-Cookie: refresh_token" },
        { "method": "POST", "path": "/auth/refresh", "auth": "cookie", "description": "Rotate refresh token, get new access token", "response": "{ access_token, token_type }" },
        { "method": "POST", "path": "/auth/logout", "auth": true, "description": "Invalidate refresh token cookie" }
      ],
      "users": [
        { "method": "GET", "path": "/users/me", "auth": true, "min_role": "viewer", "description": "Current user profile" },
        { "method": "GET", "path": "/users", "auth": true, "min_role": "admin", "description": "List tenant users (auto-filtered by tenant_id)" },
        { "method": "POST", "path": "/users", "auth": true, "min_role": "admin", "description": "Invite user to tenant", "request": "{ email, password, full_name, role }" },
        { "method": "PATCH", "path": "/users/{id}", "auth": true, "min_role": "admin", "description": "Update user role", "request": "{ role }" },
        { "method": "DELETE", "path": "/users/{id}", "auth": true, "min_role": "admin", "description": "Remove user (cannot self-delete)" }
      ],
      "assets": [
        { "method": "GET", "path": "/assets", "auth": true, "min_role": "viewer", "description": "List assets (paginated + filterable)", "query_params": "?status=draft|pending_approval|approved&page=1&size=20" },
        { "method": "GET", "path": "/assets/{id}", "auth": true, "min_role": "viewer", "description": "Single asset with AI metadata" },
        { "method": "POST", "path": "/assets", "auth": true, "min_role": "editor", "description": "Upload file (multipart/form-data)", "response_code": 202, "side_effect": "Background task: AI caption + hashtag generation" },
        { "method": "PATCH", "path": "/assets/{id}", "auth": true, "min_role": "editor", "description": "Update caption/hashtags", "request": "{ caption?, hashtags? }" },
        { "method": "DELETE", "path": "/assets/{id}", "auth": true, "min_role": "admin", "description": "Delete asset" }
      ],
      "workflow": [
        { "method": "POST", "path": "/assets/{id}/submit", "auth": true, "min_role": "editor", "description": "draft → pending_approval (owner or admin only)" },
        { "method": "POST", "path": "/assets/{id}/approve", "auth": true, "min_role": "admin", "description": "pending_approval → approved" },
        { "method": "POST", "path": "/assets/{id}/reject", "auth": true, "min_role": "admin", "description": "pending_approval → draft (with comment)", "request": "{ comment }" }
      ],
      "ai": [
        { "method": "POST", "path": "/ai/caption/{id}", "auth": true, "min_role": "editor", "description": "Regenerate caption for asset (real Claude API with vision)" },
        { "method": "POST", "path": "/ai/hashtags/{id}", "auth": true, "min_role": "editor", "description": "Regenerate hashtags for asset (real Claude API with vision)" },
        { "method": "GET", "path": "/ai/usage?days=30", "auth": true, "min_role": "admin", "description": "AI usage summary with action counts and cost breakdown" }
      ],
      "webhooks": [
        { "method": "GET", "path": "/webhooks", "auth": true, "min_role": "admin", "description": "List tenant webhooks" },
        { "method": "POST", "path": "/webhooks", "auth": true, "min_role": "admin", "description": "Create webhook (name, url, secret, events)" },
        { "method": "PATCH", "path": "/webhooks/{id}", "auth": true, "min_role": "admin", "description": "Update webhook settings" },
        { "method": "DELETE", "path": "/webhooks/{id}", "auth": true, "min_role": "admin", "description": "Delete webhook" }
      ],
      "api_keys": [
        { "method": "GET", "path": "/api-keys", "auth": true, "min_role": "admin", "description": "List API keys (prefix only, not full key)" },
        { "method": "POST", "path": "/api-keys", "auth": true, "min_role": "admin", "description": "Create API key (full key shown once)" },
        { "method": "DELETE", "path": "/api-keys/{id}", "auth": true, "min_role": "admin", "description": "Revoke API key" }
      ]
    }
  },

  "frontend_routes": [
    { "path": "/login", "component": "LoginPage", "auth": false, "description": "Email + password login form" },
    { "path": "/register", "component": "RegisterPage", "auth": false, "description": "Tenant + admin user registration" },
    { "path": "/", "component": "Navigate → /assets", "auth": true, "description": "Dashboard redirect" },
    { "path": "/assets", "component": "AssetListPage", "auth": true, "min_role": "viewer", "description": "Grid view with status filter tabs + pagination" },
    { "path": "/assets/:id", "component": "AssetDetailPage", "auth": true, "min_role": "viewer", "description": "Preview, editable metadata, approval actions" },
    { "path": "/assets/upload", "component": "UploadPage", "auth": true, "min_role": "editor", "description": "Drag-and-drop upload with progress" },
    { "path": "/team", "component": "TeamPage", "auth": true, "min_role": "admin", "description": "User table, invite form, role management" }
  ],

