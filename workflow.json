        "tasks": [
          { "id": "1.1", "task": "Create project root structure: backend/, frontend/, docker/", "status": "done" },
          { "id": "1.2", "task": "Write backend/Dockerfile (Python 3.11-slim, pip install, uvicorn)", "status": "done" },
          { "id": "1.3", "task": "Write frontend/Dockerfile (Node 20-alpine, npm install, vite dev)", "status": "done" },
          { "id": "1.4", "task": "Write docker-compose.yml with postgres, backend, frontend services", "status": "done" },
          { "id": "1.5", "task": "Define bluewave_network bridge, ensure postgres is internal-only", "status": "done" },
          { "id": "1.6", "task": "Create .env.example with all required vars", "status": "done" },
          { "id": "1.7", "task": "CHECKPOINT: docker compose up — all 3 containers healthy", "status": "done" }
        ]
      },
      {
        "id": 2,
        "name": "Database Models & Alembic Migrations",
        "status": "completed",
        "goal": "All core tables exist and are version-controlled via Alembic",
