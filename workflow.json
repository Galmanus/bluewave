        "name": "UX/UI Premium Redesign",
        "status": "completed",
        "goal": "Elevate frontend to world-class SaaS standards (Linear / Vercel / Notion tier)",
        "depends_on": [7],
        "design_brief": "docs/ux_ui_design_brief.md",
        "design_references": ["Linear", "Vercel Dashboard", "Notion", "Stripe Dashboard", "Figma", "Frame.io"],
        "deliverables": ["Design token system", "Component library (src/components/ui/)", "Redesigned pages", "Dark mode", "Animation layer", "Accessibility compliance"],
        "sub_phases": {
          "8A": {
            "name": "Design System & Component Library",
            "tasks": [
              { "id": "8A.1", "task": "Extend tailwind.config.js with full design token system (colors, typography, spacing, shadows, radii for light + dark)", "status": "done" },
              { "id": "8A.2", "task": "Install Radix UI Primitives, Framer Motion, Lucide React, cmdk, react-dropzone, sonner", "status": "done" },
              { "id": "8A.3", "task": "Create src/components/ui/Button.tsx — Primary, Secondary, Ghost, Danger variants with loading/disabled states", "status": "done" },
              { "id": "8A.4", "task": "Create src/components/ui/Input.tsx — Text input with label, error state, focus ring (shadow-focus)", "status": "done" },
              { "id": "8A.5", "task": "Create src/components/ui/Select.tsx — Custom dropdown via Radix (replace native <select>)", "status": "done" },
              { "id": "8A.6", "task": "Create src/components/ui/Badge.tsx — Status badges with dot indicator and semantic colors", "status": "done" },
