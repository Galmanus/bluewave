  "design_system": {
    "brief": "docs/ux_ui_design_brief.md",
    "philosophy": "Scandinavian minimalism meets Silicon Valley polish. Professional yet approachable. White space is a feature.",
    "references": ["Linear", "Vercel Dashboard", "Notion", "Stripe Dashboard", "Figma", "Frame.io"],
    "color_tokens": {
      "light": {
        "background": "#FAFAFA",
        "surface": "#FFFFFF",
        "surface_elevated": "#FFFFFF (with shadow)",
        "border": "#E5E7EB",
        "border_subtle": "#F3F4F6",
        "text_primary": "#111827",
        "text_secondary": "#6B7280",
