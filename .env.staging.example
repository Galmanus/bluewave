# ============================================
# Bluewave — Staging Environment Variables
# ============================================

ENV=staging

# GitHub Container Registry repository (e.g., myorg/bluewave)
GITHUB_REPOSITORY=

# PostgreSQL — use different credentials from production
POSTGRES_DB=bluewave_staging
POSTGRES_USER=bluewave_staging
POSTGRES_PASSWORD=  # Generate: openssl rand -base64 32

# JWT — different from production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# CORS — staging domain
CORS_ORIGINS=https://staging.bluewave.com

# AI (use a separate API key for staging if possible)
ANTHROPIC_API_KEY=

# Sentry — separate staging project recommended
SENTRY_DSN=

# Stripe — use test mode keys for staging
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_IDS={"pro":"price_xxx","business":"price_yyy","enterprise":"price_zzz"}
