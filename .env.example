# ============================================
# Bluewave — Development Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# Environment: development | staging | production
ENV=development

# PostgreSQL
POSTGRES_DB=bluewave
POSTGRES_USER=bluewave
POSTGRES_PASSWORD=changeme_in_production

# Database connection (used by backend)
DATABASE_URL=postgresql+asyncpg://bluewave:changeme_in_production@postgres:5432/bluewave
DATABASE_URL_SYNC=postgresql://bluewave:changeme_in_production@postgres:5432/bluewave

# JWT — CHANGE THIS! Minimum 32 characters in production.
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=dev-only-secret-do-not-use-in-production-1234567890

# CORS — comma-separated origins. Leave empty for localhost defaults in development.
CORS_ORIGINS=

# AI (Anthropic Claude API) — leave empty to use StubAIService
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO

# Sentry (optional) — leave empty to disable
SENTRY_DSN=

# Redis (optional) — leave empty to skip caching
REDIS_URL=redis://redis:6379/0

# Stripe (optional in dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_IDS=

# LangSmith (optional — AI observability)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bluewave
LANGSMITH_TRACING_ENABLED=true

# Email (Resend — optional)
RESEND_API_KEY=
EMAIL_FROM=noreply@bluewave.app
APP_URL=http://localhost:5174

# X/Twitter API (optional — for trend intelligence and social publishing)
X_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn API (optional — for social publishing)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# S3/CDN Storage (optional — default is local filesystem)
# Set STORAGE_BACKEND=s3 to use S3-compatible storage (AWS S3, Cloudflare R2, MinIO)
STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=bluewave-assets
S3_REGION=us-east-1
S3_PUBLIC_URL=
