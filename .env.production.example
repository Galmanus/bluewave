# ============================================
# Bluewave — Production Environment Variables
# ============================================
# IMPORTANT: Never commit this file with real values!
# Copy to .env.production and fill in real secrets.

ENV=production

# PostgreSQL — use strong, unique credentials
POSTGRES_DB=bluewave
POSTGRES_USER=bluewave
POSTGRES_PASSWORD=  # Generate: openssl rand -base64 32

# Database connection
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# JWT — REQUIRED, minimum 32 characters
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# CORS — REQUIRED in production, comma-separated
# Example: https://app.bluewave.com,https://www.bluewave.com
CORS_ORIGINS=

# AI (Anthropic Claude API)
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO

# Sentry — RECOMMENDED for production error tracking
SENTRY_DSN=

# Redis
REDIS_URL=redis://redis:6379/0

# Stripe — REQUIRED for billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_IDS={"pro":"price_xxx","business":"price_yyy","enterprise":"price_zzz"}
